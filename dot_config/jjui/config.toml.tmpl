# HNEI (colemak) / HJKL (qwerty) keybindings for jjui
# Layout: {{ .layout }}

{{- $down := "j" }}
{{- $up := "k" }}
{{- $right := "l" }}
{{- $new := "n" }}
{{- $edit := "e" }}
{{- $interactive := "i" }}
{{- if eq .layout "colemak" }}
{{-   $down = "n" }}
{{-   $up = "e" }}
{{-   $right = "i" }}
{{-   $new = "j" }}
{{-   $edit = "k" }}
{{-   $interactive = "l" }}
{{- end }}

# --- Navigation ---

[[bindings]]
action = "revisions.move_down"
key = "{{ $down }}"
scope = "revisions"
desc = "down"

[[bindings]]
action = "revisions.move_up"
key = "{{ $up }}"
scope = "revisions"
desc = "up"

[[bindings]]
action = "revisions.open_details"
key = "{{ $right }}"
scope = "revisions"
desc = "details"

[[bindings]]
action = "revset.edit"
key = "shift+{{ $right }}"
scope = "revisions"
desc = "revset"

# --- Displaced keys ---

[[bindings]]
action = "revisions.new"
key = "{{ $new }}"
scope = "revisions"
desc = "new"

[[bindings]]
action = "revisions.edit"
key = "{{ $edit }}"
scope = "revisions"
desc = "edit"

