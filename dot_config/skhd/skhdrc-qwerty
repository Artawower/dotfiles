# Resize windows
lctrl + ralt + rshift - h : \
    /opt/homebrew/bin/yabai -m window --resize left:-40:0 ; \
    /opt/homebrew/bin/yabai -m window --resize right:-40:0

lctrl + ralt + rshift - j : \
    /opt/homebrew/bin/yabai -m window --resize bottom:0:40 ; \
    /opt/homebrew/bin/yabai -m window --resize top:0:40

lctrl + ralt + rshift - k : \
    /opt/homebrew/bin/yabai -m window --resize top:0:-40 ; \
    /opt/homebrew/bin/yabai -m window --resize bottom:0:-40

