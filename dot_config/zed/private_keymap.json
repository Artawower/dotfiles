[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-y": "agent::Keep",
      "cmd-n": "agent::Reject",
      "cmd-.": "workspace::ActivateNextPane",
      "cmd-\\": "workspace::ToggleBottomDock",
      "cmd-w": "pane::CloseActiveItem",
      "cmd-p": "file_finder::Toggle",
      "cmd-shift-f": "workspace::NewSearch",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-k": "editor::GoToPreviousDiagnostic",
      "ctrl-j": "editor::GoToDiagnostic",
      "cmd-l": "editor::AcceptEditPrediction",
      "cmd-.": "workspace::ActivateNextPane",
      "ctrl-.": "agent::ToggleFocus",
      "cmd-j": "copilot::Suggest",
      "cmd-\\": "workspace::ToggleBottomDock",
      "cmd-<": "zed::OpenKeymap",
      "cmd->": "agent::ToggleFocus",
      "alt-x": "command_palette::Toggle",
      "ctrl-o": "pane::GoBack",
      "ctrl-i": "pane::GoForward",
      "f8": "editor::GoToDiagnostic",
      "cmd-shift-j": "assistant::ToggleFocus",
      "alt-shift-f": "editor::Format",
      "cmd-r": "editor::Rename",
      "cmd-alt-shift-p": "agent::NewThread",
    },
  },
  {
    "context": "Editor && vim_mode == helix_normal",
    "bindings": {
      "space e": "workspace::ToggleLeftDock",
      "space i": "editor::ToggleInlineValues",
    },
  },
  {
    "context": "VimControl",
    "bindings": {
      "space o p": "pane::RevealInProjectPanel",
      "space f f": "command_palette::Toggle",
      "space space": "file_finder::Toggle",
      "space p o": "projects::OpenRecent",
      "ctrl-p": "command_palette::Toggle",
      "cmd-shift-p": "command_palette::Toggle",
      "alt-x": "command_palette::Toggle",
      "space [": "pane::ActivatePreviousItem",
      "space ]": "pane::ActivateNextItem",
      "ctrl-k": "editor::GoToPreviousDiagnostic",
      "ctrl-j": "editor::GoToDiagnostic",
      "cmd-y": "agent::Keep",
      "cmd-n": "agent::Reject",
      "space p p": "projects::OpenRecent",
      "cmd-j": "copilot::Suggest",
      "cmd-l": "editor::AcceptEditPrediction",
      "space g R": "editor::ExpandAllDiffHunks",
      "space g r": "editor::ToggleSelectedDiffHunks",
      "space g ]": "editor::GoToHunk",
      "space g [": "editor::GoToPreviousHunk",
      "g ]": "editor::GoToHunk",
      "g [": "editor::GoToPreviousHunk",
      "space o t": "workspace::ToggleBottomDock",
      "space o T": "workspace::OpenInTerminal",
      "\\ p": "editor::Format",
      "\\m": "pane::JoinAll",
      // "\\h": "editor::ShowHover",
      "space g g": ["task::Spawn", { "task_name": "lazygit" }],
      "space b b": "tab_switcher::Toggle",
      "space b k": "pane::CloseActiveItem",
      "space w v": "pane::SplitRight",
      "space w s": "pane::SplitDown",
      "space w d": "pane::CloseActiveItem",
      "space w h": "workspace::ActivatePaneLeft",
      "space w l": "workspace::ActivatePaneRight",
      "space w k": "workspace::ActivatePaneUp",
      "space w j": "workspace::ActivatePaneDown",
      "space l r": "editor::Rename",
      "space l a": "editor::ToggleCodeActions",
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "shift-k": "editor::Hover",
      "space s i": "outline::Toggle",
      "space /": "workspace::NewSearch",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-w": "workspace::ToggleBottomDock",
      "ctrl-n": "workspace::NewTerminal",
      "ctrl-s": "terminal::ToggleViMode",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "left": "project_panel::CollapseSelectedEntry",
      "right": "project_panel::ExpandSelectedEntry",
      "l": "project_panel::Open",
      "h": "project_panel::CollapseSelectedEntry",
      "space e": "workspace::ToggleLeftDock",
    },
  },
]
