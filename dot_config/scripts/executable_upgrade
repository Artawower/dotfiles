#!/usr/bin/env python3
import re
import subprocess
import sys
import os

def _chezmoi_source() -> str:
    result = subprocess.run(["chezmoi", "source-path"], capture_output=True, text=True, check=True)
    return result.stdout.strip()

TEMPLATE = os.path.join(_chezmoi_source(), "dot_config", "mise.toml.tmpl")
CONFIG   = os.path.expanduser("~/.config/mise.toml")
EXCLUDE  = {"pnpm"}

excludes = ["--exclude", ",".join(EXCLUDE)]
result = subprocess.run(
    ["mise", "upgrade", "--bump"] + excludes,
    capture_output=True, text=True
)

if result.returncode != 0:
    print(result.stderr, file=sys.stderr)
    sys.exit(1)

bumped = {}
with open(CONFIG) as f:
    for line in f:
        m = re.match(r'^("?[^"={}\n]+"?)\s*=\s*"([^"]+)"', line.strip())
        if m:
            bumped[m.group(1).strip()] = m.group(2)

with open(TEMPLATE) as f:
    content = f.read()

for tool, version in bumped.items():
    if version in ("latest", "lts"):
        continue
    content = re.sub(
        rf'({re.escape(tool)}\s*=\s*")([^"]+)(")',
        rf'\g<1>{version}\g<3>',
        content
    )

with open(TEMPLATE, "w") as f:
    f.write(content)

# Re-add mise.lock so chezmoi source stays in sync with what mise wrote.
# Without this, chezmoi apply would detect an external modification and prompt.
subprocess.run(["chezmoi", "re-add", os.path.expanduser("~/.config/mise.lock")], check=True)
subprocess.run(["chezmoi", "apply", "--force"], check=True)
print("✓ Versions bumped and template updated")
