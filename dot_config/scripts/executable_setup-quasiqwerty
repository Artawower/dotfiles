#!/usr/bin/env python3
"""Install QuasiQWERTY keyboard layout on macOS (idempotent)."""

from __future__ import annotations

import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

REPO = "https://github.com/larryv/quasiqwerty.git"
BUNDLE = "QuasiQWERTY.bundle"
TARGET = Path.home() / "Library/Keyboard Layouts" / BUNDLE


def main() -> int:
    if TARGET.exists():
        print(f"QuasiQWERTY already installed at {TARGET}")
        return 0

    with tempfile.TemporaryDirectory() as tmp:
        src = Path(tmp) / "quasiqwerty"
        subprocess.run(["git", "clone", "--depth", "1", REPO, str(src)], check=True)
        TARGET.parent.mkdir(parents=True, exist_ok=True)
        shutil.copytree(src / BUNDLE, TARGET)

    print("QuasiQWERTY installed. Log out or reboot to see it in Keyboard settings.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
